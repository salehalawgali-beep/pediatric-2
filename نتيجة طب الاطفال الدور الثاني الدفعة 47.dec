<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>نتيجة طب الأطفال – الدفعة 47 (الدور الثاني) – جامعة بنغازي</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Tajawal', 'Segoe UI', Tahoma, sans-serif;
        }
        
        body {
            background: linear-gradient(145deg, #eef2f5 0%, #d4dee8 100%);
            min-height: 100vh;
            padding: 30px 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .system-container {
            max-width: 1350px;
            width: 100%;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(10px);
            border-radius: 56px;
            box-shadow: 0 30px 55px -15px rgba(0,0,0,0.35);
            padding: 35px 30px;
            border: 1px solid rgba(255,255,255,0.7);
            transition: all 0.3s ease;
        }
        
        .university-header {
            text-align: center;
            margin-bottom: 20px;
        }
        .university-header h1 {
            font-size: 2.4rem;
            font-weight: 800;
            color: #0a2f44;
            letter-spacing: -0.5px;
            text-shadow: 3px 3px 0 rgba(255,255,255,0.6);
        }
        .university-header h2 {
            font-size: 1.6rem;
            color: #1f5e8e;
            font-weight: 500;
            background: rgba(255,255,255,0.7);
            display: inline-block;
            padding: 0.2rem 2rem;
            border-radius: 60px;
            margin-top: 5px;
        }
        .university-header h3 {
            font-size: 1.3rem;
            color: #2c3e50;
            margin-top: 8px;
            font-weight: 600;
        }
        .program-badge {
            background: linear-gradient(135deg, #1e3a5f, #0f2c40);
            color: white;
            display: inline-block;
            padding: 0.6rem 2rem;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 700;
            box-shadow: 0 8px 14px -8px #0a2f44;
            margin: 12px 0 8px;
        }
        
        .system-designer {
            font-family: 'Tajawal', sans-serif;
            font-size: 1.3rem;
            color: white;
            background: linear-gradient(135deg, #1e3a5f, #0a2f44);
            display: inline-block;
            padding: 12px 32px;
            border-radius: 60px;
            box-shadow: 0 12px 20px -8px rgba(10,47,68,0.5);
            border: 2px solid #d4a76a;
            margin: 10px 0 5px;
        }
        .system-designer .highlight { color: #f5dba8; font-weight: 900; font-size: 1.4rem; margin: 0 5px; }
        
        .officials-row {
            display: flex; flex-wrap: wrap; justify-content: center; gap: 20px; margin: 20px auto 0;
            background: #eef2f6cc; border-radius: 80px; padding: 10px 25px; width: fit-content;
        }
        .officials-row span {
            background: #fff6e6; padding: 8px 25px; border-radius: 50px; color: #1e3a5f;
            font-weight: 700; box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        
        .stats-toggle-btn {
            background: linear-gradient(135deg, #f5b041, #f39c12);
            border: none; color: white; font-size: 1.25rem; font-weight: 800;
            padding: 12px 32px; border-radius: 50px; cursor: pointer;
            display: block; margin: 30px auto; box-shadow: 0 8px 18px rgba(243,156,18,0.3);
            transition: 0.25s; width: fit-content;
        }
        .stats-toggle-btn:hover { transform: translateY(-3px); box-shadow: 0 14px 24px rgba(243,156,18,0.4); }
        
        .stats-container {
            max-height: 0; overflow: hidden; transition: max-height 0.6s ease-in-out, padding 0.4s;
            background: white; border-radius: 40px; margin: 0 auto; width: 98%; opacity: 0;
        }
        .stats-container.active {
            max-height: 1150px; padding: 25px; box-shadow: 0 12px 28px rgba(0,0,0,0.1);
            margin-bottom: 35px; opacity: 1; border: 1px solid #e2eef9;
        }
        .stats-cards { display: flex; flex-wrap: wrap; gap: 15px; justify-content: center; margin-bottom: 25px; }
        .stat-card {
            background: #f8fcff; border-radius: 28px; padding: 15px 20px; text-align: center;
            min-width: 130px; flex: 1; border: 1px solid #cde3f2; box-shadow: 0 6px 12px -8px rgba(0,0,0,0.05);
        }
        .stat-card .title { font-size: 1rem; color: #1e3a5f; font-weight: 800; }
        .stat-card .val { font-size: 2rem; font-weight: 900; color: #0a2f44; line-height: 1.2; }
        .stat-card .perc { font-size: 0.9rem; font-weight: bold; color: #e67e22; }
        .charts-row { display: flex; flex-wrap: wrap; gap: 25px; justify-content: center; }
        .chart-box { background: #ffffffdd; padding: 15px; border-radius: 28px; width: 45%; min-width: 280px; }
        
        /* أزرار عرض القوائم */
        .lists-toggle-buttons {
            display: flex; justify-content: center; gap: 20px; margin: 20px 0; flex-wrap: wrap;
        }
        .toggle-list-btn {
            font-size: 1.2rem; font-weight: 800; padding: 12px 32px; border-radius: 50px; cursor: pointer; transition: 0.25s; border: none; color: white; box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }
        .pass-btn { background: linear-gradient(135deg, #2ecc71, #27ae60); }
        .pass-btn:hover { box-shadow: 0 14px 24px rgba(46,204,113,0.4); transform: translateY(-3px); }
        .fail-btn { background: linear-gradient(135deg, #e74c3c, #c0392b); }
        .fail-btn:hover { box-shadow: 0 14px 24px rgba(231,76,60,0.4); transform: translateY(-3px); }

        /* تأثير الظهور للقوائم */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* قوائم الطلاب (الناجحين والراسبين) */
        .students-lists-container {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
            margin: 10px 0 30px;
        }
        .student-list-card {
            flex: 1;
            min-width: 280px;
            background: white;
            border-radius: 48px;
            box-shadow: 0 12px 28px rgba(0,0,0,0.1);
            overflow: hidden;
            border: 1px solid #e2dccd;
        }
        .list-header {
            background: linear-gradient(135deg, #1e3a5f, #124263);
            color: white;
            padding: 18px 20px;
            font-size: 1.4rem;
            font-weight: 800;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
        }
        .list-header span:first-child {
            background: rgba(255,255,255,0.2);
            padding: 6px 18px;
            border-radius: 40px;
        }
        .print-list-btn {
            background: #f5b041;
            border: none;
            color: #1e3a5f;
            font-weight: 800;
            padding: 8px 20px;
            border-radius: 40px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .print-list-btn:hover {
            background: #e67e22;
            color: white;
            transform: scale(0.97);
        }
        .list-content {
            max-height: 400px;
            overflow-y: auto;
            padding: 10px 0;
        }
        .student-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 20px;
            border-bottom: 1px solid #eef0e5;
            transition: 0.1s;
        }
        .student-item:hover {
            background: #fff7e8;
        }
        .student-item .info {
            font-weight: 600;
            color: #153e57;
        }
        .student-item .grade-badge-small {
            font-size: 0.8rem;
            padding: 4px 12px;
            border-radius: 30px;
            color: white;
            font-weight: 700;
        }
        .student-item .id-num {
            font-family: monospace;
            background: #eef2f5;
            padding: 2px 8px;
            border-radius: 20px;
            font-size: 0.8rem;
        }
        .empty-list {
            text-align: center;
            padding: 30px;
            color: #888;
        }
        
        .top-ten-section {
            background: linear-gradient(115deg, #fef3e2, #fae9cf);
            border-radius: 70px;
            padding: 20px 25px;
            margin-bottom: 30px;
            border: 2px solid #e2b87a;
            box-shadow: 0 12px 22px -10px #b97f2e;
        }
        .top-ten-title { font-size: 1.9rem; font-weight: 800; color: #8B4513; text-align: center; margin-bottom: 12px; }
        .top-ten-select-wrapper { display: flex; justify-content: center; gap: 18px; flex-wrap: wrap; align-items: center; }
        .top-ten-label { font-size: 1.3rem; font-weight: 700; background: #fff2e0; padding: 8px 28px; border-radius: 60px; }
        .top-ten-select { font-size: 1.2rem; padding: 14px 28px; border-radius: 60px; border: 2px solid #c28a4e; background: white; min-width: 460px; font-weight: 600; cursor: pointer; }
        
        .search-card {
            background: white; border-radius: 100px; padding: 7px 7px 7px 20px;
            display: flex; align-items: center; box-shadow: 0 18px 32px -12px rgba(0,0,0,0.2);
            margin-bottom: 38px;
        }
        .search-card input {
            flex: 1; border: none; padding: 16px 20px; font-size: 1.2rem; border-radius: 80px;
            background: transparent; font-weight: 500; color: #0a2f44; direction: ltr;
        }
        .search-card input:focus { outline: none; }
        .search-card button {
            background: #1e3a5f; border: none; color: white; font-size: 1.2rem; font-weight: 700;
            padding: 12px 36px; border-radius: 60px; cursor: pointer; transition: 0.2s;
            box-shadow: 0 4px 12px rgba(30,58,95,0.4);
        }
        .search-card button:hover { background: #0f2c40; transform: scale(0.97); }
        
        .student-result {
            background: rgba(255,255,245,0.7);
            backdrop-filter: blur(8px);
            border-radius: 48px;
            padding: 20px 25px 30px;
            border: 1px solid rgba(255,255,210,0.9);
            box-shadow: 0 20px 30px -15px rgba(0,0,0,0.15);
            transition: all 0.2s;
        }
        
        .student-header {
            display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center;
            background: linear-gradient(125deg, #0a2f44, #124263); color: white;
            padding: 18px 30px; border-radius: 48px; margin-bottom: 25px;
            box-shadow: 0 10px 20px -5px rgba(0,0,0,0.2);
        }
        .student-name { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.3px; }
        .student-id { background: #f5b041; padding: 10px 28px; border-radius: 60px; font-weight: 800; font-size: 1.7rem; color: #202020; box-shadow: inset 0 1px 3px #fff9, 0 4px 6px #0002; }
        
        .grades-table {
            width: 100%; border-collapse: separate; border-spacing: 0; background: rgba(255,255,240,0.5);
            border-radius: 32px; overflow: hidden; margin-bottom: 24px; box-shadow: 0 6px 14px rgba(0,0,0,0.05);
        }
        .grades-table th {
            background: #2c6e9e; color: white; padding: 14px 8px; font-size: 1rem; font-weight: 700;
            border-bottom: 2px solid #ffe3b5;
        }
        .grades-table td {
            padding: 14px 8px; text-align: center; background: rgba(255,255,245,0.85);
            border-bottom: 1px solid #dcf0ff; font-weight: 500; color: #153e57;
        }
        .grades-table tr:last-child td { border-bottom: none; }
        .grades-table tr:hover td { background: #fff7e8; }
        
        .final-summary {
            display: flex; flex-wrap: wrap; gap: 20px; justify-content: center;
            background: #eef2f0aa; padding: 20px 15px; border-radius: 48px;
            margin: 20px 0 25px; border: 1px solid #ffdd99;
        }
        .summary-item {
            background: white; padding: 12px 35px; border-radius: 80px; text-align: center;
            min-width: 170px; box-shadow: 0 5px 12px rgba(0,0,0,0.05);
        }
        .summary-item .label { font-weight: 600; color: #2c3e50; font-size: 0.9rem; }
        .summary-item .value { font-size: 2rem; font-weight: 800; color: #0b3b5c; line-height: 1.2; }
        
        .grade-badge {
            display: inline-block; padding: 6px 16px; border-radius: 50px; font-weight: 800;
            font-size: 0.9rem; color: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        .grade-badge.excellent { background: #2e7d32; }
        .grade-badge.verygood { background: #1565c0; }
        .grade-badge.good { background: #558b2f; }
        .grade-badge.pass { background: #b06e0e; }
        .grade-badge.fail { background: #b71c1c; }
        
        .signatures {
            display: flex; flex-wrap: wrap; justify-content: center; gap: 50px;
            margin-top: 25px; padding-top: 20px; border-top: 2px dashed #d4a76a;
        }
        .signature-item { text-align: center; min-width: 200px; }
        .signature-title { font-weight: 700; color: #1f5e8e; margin-bottom: 12px; }
        .signature-line { width: 170px; height: 2px; background: #b68b40; margin: 8px auto 6px; }
        .signature-name { font-weight: 600; color: #2c3e50; }
        
        .print-btn { background: #2c5a7a; border: none; color: white; font-size: 1.2rem; padding: 12px 38px; border-radius: 60px; cursor: pointer; display: inline-flex; align-items: center; gap: 12px; box-shadow: 0 5px 12px rgba(0,0,0,0.2); transition: 0.2s; font-weight: 700; margin-top: 10px; }
        .print-btn:hover { background: #1e3e58; transform: translateY(-2px); }
        
        .footer-note {
            margin-top: 30px; text-align: center; background: #eef3f9aa; padding: 14px; border-radius: 50px;
            font-size: 0.9rem; color: #1e4663;
        }
        
        /* التعديلات الخاصة بالطباعة لتناسب صفحة واحدة */
        @media print {
            body { background: white; padding: 0; margin: 0; font-size: 14px; }
            .system-container { background: white !important; backdrop-filter: none; box-shadow: none; padding: 0; max-width: 100%; margin: 0; border-radius: 0; }
            .stats-toggle-btn, .stats-container, .top-ten-section, .search-card, .print-btn-container, .print-btn, .footer-note, .students-lists-container, .print-list-btn, .lists-toggle-buttons { display: none !important; }
            
            .student-result { background: white !important; padding: 15px !important; border: 1px solid #ddd !important; box-shadow: none !important; backdrop-filter: none; border-radius: 20px !important; margin: 0 !important; }
            .student-header { background: #0a2f44 !important; padding: 10px 25px !important; margin-bottom: 15px !important; border-radius: 20px !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .student-name { font-size: 1.5rem !important; }
            .student-id { font-size: 1.3rem !important; padding: 6px 20px !important; margin: 0 !important; }
            
            .grades-table { margin-bottom: 15px !important; border-radius: 15px !important; }
            .grades-table th { background: #2c6e9e !important; padding: 8px !important; font-size: 0.95rem !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .grades-table td { padding: 8px !important; font-size: 0.95rem !important; }
            
            .final-summary { padding: 10px !important; margin: 15px 0 !important; gap: 15px !important; border-radius: 20px !important; }
            .summary-item { padding: 8px 20px !important; min-width: 140px !important; }
            .summary-item .value { font-size: 1.5rem !important; }
            .summary-item .label { font-size: 0.85rem !important; }
            
            .signatures { margin-top: 20px !important; padding-top: 15px !important; gap: 40px !important; }
            .signature-title { font-size: 0.95rem !important; margin-bottom: 8px !important; }
            .signature-name { font-size: 0.95rem !important; }
            
            .grade-badge, .summary-item .value, .student-id { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
            .final-summary, .signatures { break-inside: avoid; page-break-inside: avoid; }
            
            /* تقليل هوامش الصفحة لتوسيع المساحة وتقليل احتمالية صفحتين */
            @page { size: A4; margin: 0.8cm; }
        }
    </style>
</head>
<body>
<div class="system-container">
    <div class="university-header">
        <h1>University of Benghazi</h1>
        <h2>جامعة بنغازي</h2>
        <h3>كلية الطب البشري</h3>
        <div class="program-badge">نتيجة مادة طب الأطفال – الدفعة 47 (الدور الثاني) – أبريل 2026</div>
        <div class="system-designer">
            <span>✨ تصميم المنظومة</span>
            <span class="highlight">د. صالح الاوجلي</span> 
            <span class="title">( رئيس قسم الدراسة والامتحانات )</span>
        </div>
        <div class="officials-row">
            <span>🧑‍⚕️ رئيس قسم طب الأطفال: د. جبريل العبيدي</span>
            <span>📋 رئيس لجنة الرصد: <strong>أ.د</strong> نادية الساحلي</span>
        </div>
    </div>

    <button class="stats-toggle-btn" id="statsToggleBtn">📊 عرض إحصائيات النتيجة (مطابقة لملف الإكسل)</button>
    
    <div class="stats-container" id="statsContainer">
        <h3 style="text-align:center; color:#0a2f44;">إحصائيات نتيجة طب الأطفال حسب معايير ملف الإكسل</h3>
        <div class="stats-cards" id="statsCardsHTML"></div>
        <div class="charts-row">
            <div class="chart-box"><canvas id="passFailChart"></canvas></div>
            <div class="chart-box"><canvas id="gradesChart"></canvas></div>
        </div>
    </div>

    <div class="lists-toggle-buttons">
        <button id="togglePassBtn" class="toggle-list-btn pass-btn">✅ عرض قائمة الناجحين</button>
        <button id="toggleFailBtn" class="toggle-list-btn fail-btn">❌ عرض قائمة الراسبين</button>
    </div>

    <div class="students-lists-container" id="studentsListsContainer">
        </div>

    <div class="top-ten-section">
        <div class="top-ten-title">🏅 الطلبة المتميزين (أعلى 10 درجات كلية) 🏅</div>
        <div class="top-ten-select-wrapper">
            <span class="top-ten-label">اختر الطالب المتميز:</span>
            <select class="top-ten-select" id="topTenSelect"><option value="">-- قائمة أعلى 10 درجات --</option></select>
        </div>
    </div>

    <div class="search-card">
        <input type="text" id="studentIdInput" placeholder="أدخل رقم القيد (مثال: 17007)" dir="ltr">
        <button id="searchBtn">🔍 عرض النتيجة التفصيلية</button>
    </div>

    <div id="resultContainer" class="student-result">
        <div style="text-align:center; padding:50px 20px;"><span style="font-size:1.8rem; font-weight:500;">📘 أدخل رقم القيد لعرض النتيجة التفصيلية</span><br><span style="color:#2c6e9e;">النجاح يتطلب: نجاح سريري (Clinic≥48) + مجموع نهائي ≥120</span></div>
    </div>
    
    <div class="footer-note">
        🔹 <strong>طريقة الحساب المطابقة لملف الإكسل الأصلي:</strong><br>
        - المجموع السريري = (History + Short1+Short2+Short3+Short4+Short5) × (2/3)   (الدرجة القصوى 80، النجاح 48)<br>
        - النتيجة النهائية = (الورقة + المجموع السريري) × (8/6)   (الدرجة القصوى 200، النجاح 120)<br>
        - <strong>لا يوجد شرط نجاح منفصل للورقة</strong>، الورقة تُحتسب ضمن المجموع فقط.<br>
        - التقديرات: ممتاز (Total ≥ 170)، جيد جداً (≥150)، جيد (≥130)، مقبول (≥120)، راسب (Total <120 أو Clinic <48).<br>
        - ✅ القائمان المنسدلتان تعرضان الناجحين (58) والراسبين (64) مع إمكانية طباعة كل قائمة.
    </div>
</div>

<script>
    // ----------------------------- البيانات -----------------------------
    const rawPediatricsData = [
        [4550,"عبدالسلام عمر محمد",0,0,0,0,0,0,0],[6316,"ادريس فرج عبدالسلام الوسيع",60.2,17.5,19,13,14,20,19],[6446,"هبة محمد المبروك",32.2,16.5,10,5,8,16.5,5],[6523,"سمية محمد سالم",0,0,0,0,0,0,0],[7008,"ايمان محمد عبدالكريم",0,0,0,0,0,0,0],[7478,"يوسف خليفة عمر ادريس",0,0,0,0,0,0,0],[7735,"نادين الحسين مفتاح علي",0,0,0,0,0,0,0],[7951,"سالم ادم عبدربه الساعدي",0,0,0,0,0,0,0],[8585,"نادر أحمد مصطفى العبيدي",0,0,0,0,0,0,0],[8709,"وفاء فرج امراجع حسن",0,0,0,0,0,0,0],[8805,"محمد عبد القادر سالم",0,0,0,0,0,0,0],[8963,"احمدعبد القادر على عبد الله",0,0,0,0,0,0,0],[9029,"بالقاسم محمد التواتي احميدة",0,0,0,0,0,0,0],[9260,"سالمة رجب امنيسي المبروك",37,7,17,19,14,9,16],[9427,"فاطمة عبدالفتاح سعيد عياد",0,0,0,0,0,0,0],[9547,"نورا فرحات شعبان",50.4,0,0,0,0,0,0],[9588,"فاطمة حسين محمد عبدالله",0,0,0,0,0,0,0],[9959,"فاطمة عبدالمجيد",27.3,0,0,0,0,0,0],[10004,"فاطمة احمد فرج الجهاني",53.2,13,13.5,6,13,12,15],[10016,"تهاني عمر الفرجاني",0,0,0,0,0,0,0],[10053,"هناء فهيم مصطفى",46.2,0,0,0,0,0,0],[10431,"اماني مسعود امحمد بوزكرة",49,15,16,16,13,9,14],[10826,"فرح مسعود محمد علي",0,0,0,0,0,0,0],[10882,"تعويضة خالد سالم ميلاد",0,0,0,0,0,0,0],[10978,"على عبدالله على",39.2,12,11,11,12,7,7],[11002,"مراد سليمان محمد",0,0,0,0,0,0,0],[11355,"بشرى فرج عبدالغنى",0,0,0,0,0,0,0],[11497,"احمد كمال عمر التربي",0,0,0,0,0,0,0],[11583,"المنجى عيسى خليل",0,0,0,0,0,0,0],[11601,"نرجس احمد ابراهيم",0,0,0,0,0,0,0],[11767,"خديجة حسين ابراهيم",0,0,0,0,0,0,0],[12039,"سعد يحمد محمد",39.1,10,10.5,17,12,17,10],[12128,"امبرة مصطفى مسعود",36.7,16,15.5,13,12,13,11],[12194,"مريم جمال السيد محمود",0,0,0,0,0,0,0],[12445,"نور محمد جاد الله",43.4,15.5,14,12,15,12.5,16],[12515,"عائشة حسن محمد",49.7,15.5,12,16,14,10,9.5],[12564,"عائشة عبدالحكيم المصراتي",0,0,0,0,0,0,0],[12749,"اسماء ونيس محمد العنيزي",47.6,17.5,12,15,15,18,9.5],[12757,"رغد ابراهيم محمد صالح",43.4,16.5,8,4,11,15,7.5],[12848,"يوسف ادريس يوسف ادم",38.5,13,14.5,18,14,14,10],[12872,"سناء فرج الهادي مفتاح",46.2,18,15,11,16,13,11],[12904,"خولة محمد علي العباني",48.3,18,16.5,19,17,16,11],[12958,"عفراء رزق محمد خليفة",0,0,0,0,0,0,0],[13217,"نورهان عادل عودة",36.4,18,14,18,15,15,9],[13219,"مبروكة فضل الله عبدالقادر",47.6,15,13,10,10,10,10],[13413,"سعد الدين سالم محمد القيش",35.7,13,11,17,13,12,6],[13475,"محمود مصطفى محمد",0,0,0,0,0,0,0],[13689,"احلام اسامة سالم الشريف",0,0,0,0,0,0,0],[13722,"خلود محمد راف الله صالح",50.4,0,0,0,0,0,0],[13744,"اسماعيل حسين اسويكر موسى",0,0,0,0,0,0,0],[13753,"أميرة توفيق أحمد المكاس",43.4,17,13,16,15,7.5,7],[13857,"حنين يوسف عمر سعيد",37.1,15,11,13,10,13,8],[13861,"حليم عبدالسلام جمعة العرفي",46.9,18.5,12,12.5,16,13.5,10],[13910,"حواء صلاح الدين سعد",51.8,16,15,17,16,11,12.5],[13949,"مريم أسامة مفتاح المسماري",46.9,14.5,13,13.5,10,7,14],[14152,"بشير طارق بشير",21.7,0,0,0,0,0,0],[14176,"سالم محمد سالم",42,14,15,13,15,17,16.5],[14300,"منى عادل حمودة",0,0,0,0,0,0,0],[14336,"بالقاسم صالح جبريل",55.3,8,16,12,16,14,15],[14349,"محمد يونس صالح",0,0,0,0,0,0,0],[14414,"صفاء محمد خليفة",46.2,17,16,18,11,17,11],[14419,"الرفاعي محجوب مفتاح",36.3,16,11.5,14,14,15.5,10],[14461,"مروة مفتاح محمد",0,0,0,0,0,0,0],[14545,"حسين نجيب فرج",0,0,0,0,0,0,0],[14565,"موسى محمد موسى",0,0,0,0,0,0,0],[14732,"نادية محمد ابكر",42,16,13.5,14,13,13,12],[14775,"وفاء عبد العزيز على",50.4,14.5,13.5,17,13,15,10],[15005,"ندى إسماعيل سالم إمحارب",54.6,18,17,18,16,17,19],[15033,"عبدالكريم حمد عبدالكريم السيفي",56,15,12,12.5,12,9.5,13],[15045,"مراد سعيد محمد صالح",38.5,13.5,11,12,13,11,9],[15212,"إيناس علي حسين أبوبكر",46.2,15.8,11,17,12,15.5,11],[15215,"مبروكة سامي ناجي مفتاح",53.9,16,20,16,10,16,16],[15529,"ندى محمد جابر إبراهيم",43.4,10,9.5,9.5,13,12,8],[15658,"إستبرق مرعي فرج",37.8,7.5,8.5,15,10,15,9],[15711,"رانيا عبدالله ميلاد الفيتوري",43.4,12,7,14,17,16,13.5],[15735,"مفتاح محمد علي سالم",52.5,18,13,12,17,17,18],[15745,"نجاة مصطفى بشير علي",36.7,11,17.5,15.5,12,15,10],[15761,"منى عبدالغني محفوظ عبدالغني",44.1,14,12,14.5,12,14,9],[15767,"ملاك رجب حسين عثمان العوشار",38.5,10,19,15,17,18,13],[15817,"مريم علي صالح إحواس",0,0,0,0,0,0,0],[15976,"عبدالله محمود إقدورة",0,0,0,0,0,0,0],[15978,"ابراهيم احمد ابراهيم الدوفاني",49.7,13,18,8,14,11,12],[16047,"هناء رجب الحسين",58.1,14,15,15,12,11.5,13],[16063,"محمد حسن عبدالقادر",0,0,0,0,0,0,0],[16129,"آلاء أحمد الهادي حمد",42.7,8,14,11,17,10,10],[16146,"فادي فيصل نوري مفتاح",46.9,9,16,13,10,15,13],[16177,"فرح عبدالوهاب صالح عبدالسلام",47.6,10,11,14,15,10,12],[16220,"سهيل مصطفى محمد العريبي",0,0,0,0,0,0,0],[16231,"هبة جمعة محمد أحمد",42.7,13,14,17,16,17,15],[16251,"غادة سالم علي محمد",45.5,8,13,17,17,14,13],[16266,"سلمى أحمد إبراهيم الدوفاني",0,0,0,0,0,0,0],[16310,"زينب محمد آدم موسى",47.6,13,13,13,14,12,12],[16383,"فاطمة رمضان عمر الفيتوري",56,11.5,10,10.5,16,12,12],[16396,"هبة طاهر بوبكر البرغثي",0,0,0,0,0,0,0],[16409,"أوريدة رمضان رمضان الشواي",0,0,0,0,0,0,0],[16533,"ايه مرعي فرج سعيد",0,0,0,0,0,0,0],[16645,"منيرة عبدالسلام حامد القذافي",48.3,10,8.5,8.5,14,11,12],[16668,"اكرم طاهر محمد",49.7,3,15.5,9.5,10,12,9],[16708,"حنين محمد يونس عبدالله",41.3,14,16,17,9,17,10],[16751,"عبدالقادرعلي محمد علي العلام",0,0,0,0,0,0,0],[16887,"سماح رزق الله سعد",56.7,16,8,14,14,17,12],[16909,"ابتهال محمد فرج",53.2,12.5,12,10.5,15,10,12],[16916,"مودة عبدالجواد موسى",54.6,9,18,16,16,14,12],[17002,"هناء صلاح محمد ناجي",62.3,9,18,16,10,16,11],[17007,"أحمد عبدالغني عبدالرحيم يونس",63.7,14,20,16,15,17,17],[17009,"أحمد خالد السنوسي عبدالله",49.7,0,0,0,0,0,0],[17036,"عبدالحكيم محمد فرج مفتاح",47.6,13,18.5,16,15,16,19],[17048,"سارة عبدالرحيم عياد البرغثي",56.7,11.5,15,18,5,11,8],[17050,"أريج محمد علي محمد",49,13.5,16,20,18,15,14],[17075,"محمد فرج محمد فرج",58.8,17,12,17,16,17,17],[17146,"عطية سالم محمد عبدالونيس",48.3,9,20,17,17,15,15],[17206,"غادة صالح جمعة محمد",60.9,14,12,11.5,13,16,12],[17218,"منية مسعود محمد مسعود",56.7,11,15,17.5,17,14,11],[17219,"آلاء محمد مفتاح شبش",58.8,14.5,15.5,17,13,16,14],[17297,"المعتز بالله راف الله عيسى",43.4,16,17,13,14,12,15],[17379,"مريم نوري فرج بن شتوان",53.2,14.5,13,17,18,15,14],[17583,"حسين أبوبكر حسين بوخشيم",0,0,0,0,0,0,0],[17605,"مصطفى مازن عبيد",0,0,0,0,0,0,0],[17618,"يعقوب عبدالقادر صالح علي السحاقي",42,12,16,15,15,12,12],[17624,"علي الصافي عبدالعزيز محمد",53.9,19,12,13,16,16,18],[50184,"لجينا محمد عبد الرازق",61.6,13.5,14.5,17,14,12,12],[600532,"سوزان اغنيوة السنوسي",0,0,0,0,0,0,0]
    ];

    const PASS_CLINIC = 48;
    const PASS_TOTAL = 120;
    const MAX_TOTAL = 200;

    const studentsMap = new Map();
    
    rawPediatricsData.forEach(row => {
        const id = row[0];
        const name = row[1];
        const paper = parseFloat(row[2]);
        const history = parseFloat(row[3]), short1 = parseFloat(row[4]), short2 = parseFloat(row[5]);
        const short3 = parseFloat(row[6]), short4 = parseFloat(row[7]), short5 = parseFloat(row[8]);
        
        const rawSum = history + short1 + short2 + short3 + short4 + short5;
        let clinic = rawSum * (2/3);
        clinic = Math.round(clinic * 100) / 100;
        let totalRaw = (paper + clinic) * (8/6);
        let total = Math.round(totalRaw * 100) / 100;
        
        const clinicPass = clinic >= PASS_CLINIC;
        const totalPass = total >= PASS_TOTAL;
        const finalPass = clinicPass && totalPass;
        
        let finalGrade = "";
        if (!clinicPass) {
            finalGrade = "راسب";
        } else if (total >= 170) {
            finalGrade = "ممتاز";
        } else if (total >= 150) {
            finalGrade = "جيد جدا";
        } else if (total >= 130) {
            finalGrade = "جيد";
        } else if (total >= 120) {
            finalGrade = "مقبول";
        } else {
            finalGrade = "راسب";
        }
        
        studentsMap.set(id, { id, name, paper, history, short1, short2, short3, short4, short5,
            clinicTotal: clinic, clinicPass, total, finalGrade, percent: ((total/MAX_TOTAL)*100).toFixed(2), finalPass });
    });

    // إحصائيات
    let totalStd = studentsMap.size;
    let gradeCount = { ممتاز:0, "جيد جدا":0, جيد:0, مقبول:0, راسب:0 };
    for (let s of studentsMap.values()) {
        gradeCount[s.finalGrade]++;
    }
    let stats = {
        total: totalStd,
        pass: totalStd - gradeCount["راسب"],
        fail: gradeCount["راسب"],
        excellent: gradeCount["ممتاز"],
        verygood: gradeCount["جيد جدا"],
        good: gradeCount["جيد"],
        passGrade: gradeCount["مقبول"]
    };

    document.getElementById('statsCardsHTML').innerHTML = `
        <div class="stat-card"><div class="title">العدد الكلي</div><div class="val">${stats.total}</div></div>
        <div class="stat-card pass"><div class="title">الناجحون</div><div class="val">${stats.pass}</div><div class="perc">${((stats.pass/totalStd)*100).toFixed(1)}%</div></div>
        <div class="stat-card"><div class="title">الراسبون</div><div class="val">${stats.fail}</div><div class="perc">${((stats.fail/totalStd)*100).toFixed(1)}%</div></div>
        <div class="stat-card pass"><div class="title">ممتاز</div><div class="val">${stats.excellent}</div><div class="perc">${((stats.excellent/totalStd)*100).toFixed(1)}%</div></div>
        <div class="stat-card pass"><div class="title">جيد جداً</div><div class="val">${stats.verygood}</div><div class="perc">${((stats.verygood/totalStd)*100).toFixed(1)}%</div></div>
        <div class="stat-card pass"><div class="title">جيد</div><div class="val">${stats.good}</div><div class="perc">${((stats.good/totalStd)*100).toFixed(1)}%</div></div>
        <div class="stat-card pass"><div class="title">مقبول</div><div class="val">${stats.passGrade}</div><div class="perc">${((stats.passGrade/totalStd)*100).toFixed(1)}%</div></div>
    `;

    let chartsRendered = false;
    document.getElementById('statsToggleBtn').addEventListener('click', function() {
        const container = document.getElementById('statsContainer');
        container.classList.toggle('active');
        if(container.classList.contains('active') && !chartsRendered) {
            new Chart(document.getElementById('passFailChart'), {
                type: 'doughnut',
                data: { labels: ['ناجحون', 'راسبون'], datasets: [{ data: [stats.pass, stats.fail], backgroundColor: ['#2ecc71', '#e74c3c'] }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            new Chart(document.getElementById('gradesChart'), {
                type: 'bar',
                data: { labels: ['ممتاز', 'جيد جداً', 'جيد', 'مقبول'], datasets: [{ label: 'الطلاب', data: [stats.excellent, stats.verygood, stats.good, stats.passGrade], backgroundColor: '#2c6e9e' }] },
                options: { responsive: true, plugins: { legend: { display: false } } }
            });
            chartsRendered = true;
        }
    });

    // بناء قوائم الناجحين والراسبين (تم التعديل للترتيب حسب رقم القيد تصاعدياً)
    const passedStudents = Array.from(studentsMap.values()).filter(s => s.finalPass).sort((a,b)=> a.id - b.id);
    const failedStudents = Array.from(studentsMap.values()).filter(s => !s.finalPass).sort((a,b)=> a.id - b.id);
    
    function getGradeClassForBadge(grade) {
        if(grade === "ممتاز") return "excellent";
        if(grade === "جيد جدا") return "verygood";
        if(grade === "جيد") return "good";
        if(grade === "مقبول") return "pass";
        return "fail";
    }
    
    function renderListCard(title, studentsList, isPassed, gradeShow = true) {
        let cardId = isPassed ? "passListCard" : "failListCard";
        let html = `<div class="student-list-card" id="${cardId}" style="display: none; animation: fadeIn 0.4s ease-in-out;">
                        <div class="list-header">
                            <span>${title} (${studentsList.length})</span>
                            <button class="print-list-btn" data-list-type="${isPassed ? 'pass' : 'fail'}">🖨️ طباعة القائمة</button>
                        </div>
                        <div class="list-content">`;
        if(studentsList.length === 0) {
            html += `<div class="empty-list">لا يوجد طلاب</div>`;
        } else {
            studentsList.forEach(s => {
                html += `<div class="student-item">
                            <div class="info">
                                <strong>${s.name}</strong> <span class="id-num">${s.id}</span>
                            </div>
                            <div>`;
                if(gradeShow) {
                    html += `<span class="grade-badge-small ${getGradeClassForBadge(s.finalGrade)}">${s.finalGrade}</span>`;
                } else {
                    html += `<span class="grade-badge-small fail">راسب</span>`;
                }
                html += `</div></div>`;
            });
        }
        html += `</div></div>`;
        return html;
    }
    
    const listsContainer = document.getElementById('studentsListsContainer');
    listsContainer.innerHTML = renderListCard("✅ الطلاب الناجحون", passedStudents, true, true) + 
                               renderListCard("❌ الطلاب الراسبون", failedStudents, false, false);
    
    // منطق أزرار العرض والإخفاء للقوائم
    const togglePassBtn = document.getElementById('togglePassBtn');
    const toggleFailBtn = document.getElementById('toggleFailBtn');
    const passListCard = document.getElementById('passListCard');
    const failListCard = document.getElementById('failListCard');

    togglePassBtn.addEventListener('click', () => {
        if (passListCard.style.display === 'none') {
            passListCard.style.display = 'block';
            togglePassBtn.innerHTML = '✅ إخفاء قائمة الناجحين';
            togglePassBtn.style.background = 'linear-gradient(135deg, #27ae60, #1e8449)';
        } else {
            passListCard.style.display = 'none';
            togglePassBtn.innerHTML = '✅ عرض قائمة الناجحين';
            togglePassBtn.style.background = 'linear-gradient(135deg, #2ecc71, #27ae60)';
        }
    });

    toggleFailBtn.addEventListener('click', () => {
        if (failListCard.style.display === 'none') {
            failListCard.style.display = 'block';
            toggleFailBtn.innerHTML = '❌ إخفاء قائمة الراسبين';
            toggleFailBtn.style.background = 'linear-gradient(135deg, #c0392b, #922b21)';
        } else {
            failListCard.style.display = 'none';
            toggleFailBtn.innerHTML = '❌ عرض قائمة الراسبين';
            toggleFailBtn.style.background = 'linear-gradient(135deg, #e74c3c, #c0392b)';
        }
    });

    // إضافة وظيفة طباعة لكل قائمة
    document.querySelectorAll('.print-list-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const type = btn.getAttribute('data-list-type');
            let title, students, showGrade;
            if(type === 'pass') {
                title = "قائمة الطلاب الناجحين - طب الأطفال الدفعة 47";
                students = passedStudents;
                showGrade = true;
            } else {
                title = "قائمة الطلاب الراسبين - طب الأطفال الدفعة 47";
                students = failedStudents;
                showGrade = false;
            }
            let printContent = `
                <html dir="rtl">
                <head><meta charset="UTF-8"><title>${title}</title>
                <style>
                    body { font-family: 'Tajawal', sans-serif; margin: 20px; direction: rtl; }
                    h2 { color: #0a2f44; text-align: center; }
                    .sub { text-align: center; margin-bottom: 20px; }
                    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
                    th, td { border: 1px solid #aaa; padding: 10px; text-align: right; }
                    th { background: #1e3a5f; color: white; }
                    .grade { display: inline-block; padding: 3px 10px; border-radius: 20px; color: white; font-size: 0.8rem; }
                    .excellent { background: #2e7d32; }
                    .verygood { background: #1565c0; }
                    .good { background: #558b2f; }
                    .pass { background: #b06e0e; }
                    .fail { background: #b71c1c; }
                    .footer { margin-top: 30px; text-align: center; font-size: 0.8rem; border-top: 1px solid #ccc; padding-top: 15px; }
                </style>
                </head>
                <body>
                <h2>جامعة بنغازي - كلية الطب البشري</h2>
                <div class="sub"><strong>${title}</strong><br>الدفعة 47 – الدور الثاني – أبريل 2026</div>
                <table>
                    <thead><tr><th>#</th><th>رقم القيد</th><th>الاسم</th>${showGrade ? '<th>التقدير</th>' : ''}</tr></thead>
                    <tbody>
            `;
            students.forEach((s, idx) => {
                printContent += `<tr>
                                    <td>${idx+1}</td>
                                    <td>${s.id}</td>
                                    <td>${s.name}</td>
                                    ${showGrade ? `<td><span class="grade ${getGradeClassForBadge(s.finalGrade)}">${s.finalGrade}</span></td>` : ''}
                                </tr>`;
            });
            printContent += `
                    </tbody>
                </table>
                <div class="footer">تم الإنشاء بواسطة منظومة د. صالح الاوجلي – رئيس قسم الدراسة والامتحانات</div>
                <script>setTimeout(() => { window.print(); window.close(); }, 300);<\/script>
                </body></html>
            `;
            const printWin = window.open('', '_blank');
            printWin.document.write(printContent);
            printWin.document.close();
        });
    });
    
    // أفضل 10 طلاب
    const topTen = Array.from(studentsMap.values()).sort((a,b)=> b.total - a.total).slice(0,10);
    const topSelect = document.getElementById('topTenSelect');
    topTen.forEach((st, idx) => {
        let opt = document.createElement('option');
        opt.value = st.id;
        opt.textContent = `${idx===0?"🥇":idx===1?"🥈":idx===2?"🥉":"⭐"} ${st.name} (${st.total} درجة)`;
        topSelect.appendChild(opt);
    });
    
    function renderStudent(s) {
        const clinicText = s.clinicPass ? `✅ ناجح سريرياً (${s.clinicTotal}/80)` : `❌ راسب سريرياً (${s.clinicTotal}/80)`;
        return `
            <div class="student-header">
                <span class="student-name">${s.name}</span>
                <span class="student-id">${s.id}</span>
            </div>
            <table class="grades-table">
                <thead><tr><th>الاختبار</th><th>الدرجة / العظمى</th><th>الملاحظة</th></tr></thead>
                <tbody>
                    <tr><td>📄 الورقة (Paper) 70 درجة</td><td>${s.paper} / 70</td><td>-</td></tr>
                    <tr><td>📋 History</td><td>${s.history} / 20</td><td>-</td></tr>
                    <tr><td>📌 Short Case 1</td><td>${s.short1} / 20</td><td>-</td></tr>
                    <tr><td>📌 Short Case 2</td><td>${s.short2} / 20</td><td>-</td></tr>
                    <tr><td>📌 Short Case 3</td><td>${s.short3} / 20</td><td>-</td></tr>
                    <tr><td>📌 Short Case 4</td><td>${s.short4} / 20</td><td>-</td></tr>
                    <tr><td>📌 Short Case 5</td><td>${s.short5} / 20</td><td>-</td></tr>
                    <tr style="background:#fff1e0;"><td><strong>🏥 المجموع السريري (Clinic) 80 درجة</strong></td><td><strong>${s.clinicTotal} / 80</strong></td><td><span class="grade-badge ${s.clinicPass?'pass':'fail'}">${clinicText}</span></td></tr>
                </tbody>
            </table>
            <div class="final-summary">
                <div class="summary-item"><div class="label">المجموع الكلي (ورقة+كلينك)×8/6</div><div class="value">${s.total} / 200</div></div>
                <div class="summary-item"><div class="label">التقدير النهائي</div><div class="value" style="background:${s.finalGrade.includes('راسب')?'#b71c1c':'#1f6392'}; padding:0 20px; border-radius:60px; color:white;">${s.finalGrade}</div></div>
                <div class="summary-item"><div class="label">النسبة المئوية</div><div class="value">${s.percent}%</div></div>
            </div>
            <div class="signatures">
                <div class="signature-item"><div class="signature-title">رئيس قسم طب الأطفال</div><div class="signature-line"></div><div class="signature-name">د. جبريل العبيدي</div></div>
                <div class="signature-item"><div class="signature-title">رئيس لجنة الرصد</div><div class="signature-line"></div><div class="signature-name"><strong>أ.د</strong> نادية الساحلي</div></div>
            </div>
        `;
    }
    
    const searchBtn = document.getElementById('searchBtn');
    const idInput = document.getElementById('studentIdInput');
    const resultDiv = document.getElementById('resultContainer');
    
    searchBtn.onclick = () => {
        const idNum = Number(idInput.value);
        const student = studentsMap.get(idNum);
        if (!student) {
            resultDiv.innerHTML = `<div style="text-align:center; padding:40px;"><span style="font-size:1.6rem;">⚠️ لا يوجد طالب بهذا الرقم، تأكد من رقم القيد</span></div>`;
            return;
        }
        resultDiv.innerHTML = renderStudent(student) + `<div class="print-btn-container" style="text-align:center; margin-top:25px;"><button class="print-btn" id="printResultBtn">🖨️ طباعة النتيجة</button></div>`;
        document.getElementById('printResultBtn').onclick = () => {
            const printWin = window.open('','_blank');
            const styleContent = document.querySelector('style').innerHTML;
            printWin.document.write(`<html dir="rtl"><head><title>نتيجة ${student.name} - طب الأطفال</title><style>${styleContent}</style></head><body><div class="system-container" style="background:white; padding:15px;"><div style="text-align:center; margin-bottom:15px;"><h2>جامعة بنغازي - كلية الطب البشري</h2><h3>نتيجة مادة طب الأطفال – الدفعة 47</h3></div>${renderStudent(student)}</div><script>setTimeout(() => { window.print(); window.close(); }, 400);<\/script></body></html>`);
            printWin.document.close();
        };
    };
    
    topSelect.onchange = (e) => {
        if (e.target.value) {
            idInput.value = e.target.value;
            searchBtn.click();
        }
    };
</script>
</body>
</html>